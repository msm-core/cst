{
  "name": "@msm-core/cst",
  "version": "0.3.2",
  "description": "Contextual Semantic Tokenizer — zero-dependency, multilingual, reversible",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "vocab",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/msm-core/cst.git"
  },
  "scripts": {
    "vocab": "node scripts/build-vocab.mjs",
    "profile": "node scripts/lit-profiler.mjs",
    "profile:en": "node scripts/lit-profiler.mjs --dataset en",
    "profile:ar": "node scripts/lit-profiler.mjs --dataset ar",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "tokenizer",
    "semantic",
    "nlp",
    "arabic",
    "english",
    "hdc",
    "zero-dependency"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  }
}
